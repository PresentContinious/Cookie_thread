mainmenu "Cookie sensor node"

choice
	prompt "Node operation profile"
	default NODE_PROFILE_AUTO
	help
	  Selects the runtime shape of the node. AUTO is the headline
	  self-organising-mesh image (FTD, role elected by Thread).
	  SED is the sleepy-end-device variant for low-power measurement.

config NODE_PROFILE_AUTO
	bool "AUTO — FTD, role elected by Thread"

config NODE_PROFILE_SED
	bool "SED — sleepy end device, periodic wake"

endchoice

config NODE_REPORT_INTERVAL_SEC
	int "Sensor reporting cadence (seconds)"
	default 5  if NODE_PROFILE_AUTO
	default 30 if NODE_PROFILE_SED

# Thread network credentials live in upstream Kconfig:
#   CONFIG_OPENTHREAD_NETWORK_NAME
#   CONFIG_OPENTHREAD_NETWORKKEY
#   CONFIG_OPENTHREAD_PANID
#   CONFIG_OPENTHREAD_XPANID
#   CONFIG_OPENTHREAD_CHANNEL
# Defaults are set in apps/sensor_node/prj.conf and apply to every node and
# the gateway, so the whole mesh shares one identity at flash time.

source "Kconfig.zephyr"
